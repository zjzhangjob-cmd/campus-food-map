# ── 数据库（MySQL）──────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/campus_food?charset=utf8mb4

# ── JWT 认证 ──────────────────────────────────────────────────
SECRET_KEY=请替换为随机长字符串
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI 推荐（Anthropic Claude）────────────────────────────────
# 申请：https://console.anthropic.com  不填则退化为规则推荐
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── 高德地图 Web 服务 Key（后端地理编码）────────────────────────
# 申请：https://console.amap.com → 创建应用 → Web服务
AMAP_KEY=你的高德WebServiceKey

# ── 其他 ─────────────────────────────────────────────────────
APP_NAME=觅食·大学城美食地图
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500
